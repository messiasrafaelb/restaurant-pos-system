<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDV - Luizão Lanches</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="sidebar">
        <div>
            <div class="logo mb-4">
                <img src="/img/logo.png" alt="Logo">
            </div>

            <div class="menu">
                <button class="menu-item a active" data-tela="tela-venda">
                    <i class="bi bi-cart-fill"></i>
                    Venda
                </button>

                <button class="menu-item b" data-tela="tela-pedidos">
                    <i class="bi bi-receipt"></i>
                    Pedidos
                </button>

                <button class="menu-item e" data-tela="tela-relatorios">
                    <i class="bi bi-bar-chart"></i>
                    Relatórios
                </button>

                <button class="menu-item c" data-tela="tela-produtos">
                    <i class="bi bi-box2-heart"></i>
                    Produtos
                </button>

                <button class="menu-item d" data-tela="tela-estoque">
                    <i class="bi bi-box-seam"></i>
                    Estoque
                </button>
            </div>
        </div>
    </div>

    <div class="main">
        <div class="topbar">
            <h3 class="fw-bold mb-0">PDV - PONTO DE VENDA</h3>

            <div class="d-flex align-items-center gap-4">
                <span>
                    <i class="bi bi-calendar-event me-2"></i>
                    <span id="dataAtual"></span>
                </span>

                <span>
                    <i class="bi bi-clock me-2"></i>
                    <span id="horaAtual"></span>
                </span>

                <div class="user-box w-100">
                    <div class="fw-bold">Caixa 01</div>
                    <small>Administrador</small>
                </div>
            </div>
        </div>

        <div class="content container-fluid">

            <div id="tela-venda" class="row h-100 m-0 item-tela">
                <div class="col-lg-8 products-area">
                    <div class="row mb-4">
                        <div class="col-lg-9">
                            <input id="searchInput" type="text" class="form-control search-input" placeholder="Buscar produtos...">
                        </div>
                    </div>

                    <div class="row mb-4 g-3">
                        <div class="col-md-4">
                            <button id="item-lanche" class="category-btn active" data-category="lanche">Lanches</button>
                        </div>
                        <div class="col-md-4">
                            <button class="category-btn" data-category="bebida">Bebidas</button>
                        </div>
                        <div class="col-md-4">
                            <button class="category-btn" data-category="sobremesa">Sobremesas</button>
                        </div>
                    </div>

                    <div id="productsGrid" class="row g-4">
                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="X-Burguer" data-preco="18" data-category="lanche" data-stock="8" data-img="/img/Xburguer2.png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/Xburguer2.png" alt="Burger">
                                </div>
                                <div class="product-title">X-Burguer</div>
                                <div class="product-description">Pão artesanal, carne, queijo, alface e tomate.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 18,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="Batata Frita" data-preco="15" data-category="lanche" data-stock="10" data-img="/img/batata.png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/batata.png" alt="fritas">
                                </div>
                                <div class="product-title">Batatas c/Bacon</div>
                                <div class="product-description">500g Batata bacon e cheddar.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 15,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="Nuggets" data-preco="16" data-category="lanche" data-stock="15" data-img="/img/nugget.png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/nugget.png" alt="nugget">
                                </div>
                                <div class="product-title">Nuggets</div>
                                <div class="product-description">12 unidades de nuggets super crocante.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 16,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="X-Bacon" data-preco="24" data-category="lanche" data-stock="6" data-img="/img/xbacon%20(2).png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/xbacon (2).png" alt="Burger">
                                </div>
                                <div class="product-title">X-Bacon</div>
                                <div class="product-description">Pão artesanal, queijo e bacon crocante.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 24,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="Refrigerante" data-preco="7" data-category="bebida" data-stock="20" data-img="/img/refrigerante%20(2).png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/refrigerante (2).png" alt="refrigerante">
                                </div>
                                <div class="product-title">Refrigerante</div>
                                <div class="product-description">Refrigerante Lata 350ml, bem gelada.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 7,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="Suco Natural" data-preco="9" data-category="bebida" data-stock="12" data-img="/img/suco.png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/suco.png" alt="suco">
                                </div>
                                <div class="product-title">Suco Natural</div>
                                <div class="product-description">Suco Natural de laranja 300ml.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 9,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-6">
                            <div class="product-card" data-nome="Milkshake" data-preco="14" data-category="sobremesa" data-stock="10" data-img="/img/milkshake.png">
                                <div class="imagem">
                                    <img src="/restaurant-pos-system/src/public/img/milkshake.png" alt="milkshake">
                                </div>
                                <div class="product-title">Milkshake</div>
                                <div class="product-description">Milkshake crocante de Ovomaltine 400ml.</div>
                                <div class="d-flex justify-content-between align-items-center mt-4">
                                    <div class="price">R$ 14,00</div>
                                    <button class="add-btn">+</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 order-area d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-bold mb-0">Pedido Atual</h2>
                            <button id="limparPedido" class="btn clear-btn">Limpar pedido</button>
                        </div>
                        <div id="pedidoAtual">
                            </div>
                    </div>

                    <div class="fundo mt-auto w-100">
                        <div class="p-2 text-center border rounded-3 bg-light mb-4">
                            <h5 class="m-0 fw-bold text-muted">Subtotal: <span id="subtotal">R$ 0,00</span></h5>
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-12">
                                <div class="pay-card">
                                    <button id="finalizarPedido" data-tela="tela-dinheiro" class="btn text-white bg-success w-100 py-3 fw-bold fs-5 rounded-3 border-0">Finalizar Venda</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="tela-dinheiro" class="p-4 item-tela d-none">
                <h2 class="fw-bold text-dark mb-4"><i class="bi bi-cash-stack me-2"></i>Escolha o Método de Pagamento</h2>
                <div class="bg-white p-4 rounded-4 shadow-sm">
                    <div id="paymentSummary" class="mb-4 fs-5 fw-semibold text-secondary"></div>
                    <div class="d-flex flex-wrap gap-3">
                        <button type="button" class="btn btn-success btn-lg payment-method-btn px-4" data-method="Dinheiro">
                            <i class="bi bi-currency-dollar me-2"></i>Dinheiro
                        </button>
                        <button type="button" class="btn btn-primary btn-lg payment-method-btn px-4" data-method="Cartão" data-tela="tela-cartao">
                            <i class="bi bi-credit-card-2-front me-2"></i>Cartão
                        </button>
                        <button type="button" class="btn btn-warning btn-lg payment-method-btn px-4 text-dark" data-method="Pix">
                            <i class="bi bi-qr-code-scan me-2"></i>Pix
                        </button>
                    </div>
                    <div class="mt-5 border-top pt-4">
                        <button id="voltarVenda" class="btn btn-secondary px-4" data-tela="tela-venda">
                            <i class="bi bi-arrow-left me-2"></i>Voltar para Venda
                        </button>
                    </div>
                    <div id="paymentMessage" class="mt-3 text-success fw-bold"></div>
                </div>
            </div>

            <div id="tela-cartao" class="p-4 item-tela d-none">
                <h2 class="fw-bold text-dark mb-4"><i class="bi bi-credit-card-2-front me-2"></i>Cartão: Detalhes da Transação</h2>
                <div class="bg-white p-4 rounded-4 shadow-sm">
                    <div id="cardTypeMessage" class="mb-4 text-muted fs-5">Selecione a operação do cartão correspondente:</div>
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <button type="button" class="btn btn-outline-primary btn-lg px-4" data-card-type="Débito">
                            <i class="bi bi-credit-card me-2"></i>Débito
                        </button>
                        <button type="button" class="btn btn-outline-primary btn-lg px-4" data-card-type="Crédito">
                            <i class="bi bi-credit-card-2-back me-2"></i>Crédito
                        </button>
                    </div>

                    <div id="opcao-parcelas" class="mb-4" style="max-width: 320px;">
                        <label class="form-label fw-semibold text-secondary">Quantidade de Parcelas</label>
                        <select class="form-select form-select-lg">
                            <option value="1">1x (À vista no crédito)</option>
                            <option value="2">2x</option>
                            <option value="3">3x</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2 border-top pt-4">
                        <button id="confirmarPagamentoCartao" class="btn btn-success btn-lg fw-bold px-4">Confirmar Transação</button>
                        <button id="voltarMetodo" class="btn btn-secondary btn-lg px-4" data-tela="tela-dinheiro">Voltar</button>
                    </div>
                </div>
            </div>

            <div id="tela-pedidos" class="p-4 item-tela d-none">
                <h2 class="fw-bold text-dark mb-4"><i class="bi bi-receipt me-2"></i>Histórico de Pedidos Fechados</h2>
                <div class="bg-white p-4 rounded-4 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Nº Pedido</th>
                                    <th>Horário</th>
                                    <th>Itens / Detalhes</th>
                                    <th>Valor Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody id="pedidosList">
                                <tr>
                                    <td class="fw-bold">#1024</td>
                                    <td>19:42</td>
                                    <td>1x X-Bacon, 1x Refrigerante</td>
                                    <td class="fw-semibold text-success">R$ 31,00</td>
                                    <td><span class="badge bg-success px-2 py-2">Concluído</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">#1023</td>
                                    <td>19:35</td>
                                    <td>2x X-Tudo, 1x Batatas c/Bacon, 1x Suco Natural</td>
                                    <td class="fw-semibold text-success">R$ 54,00</td>
                                    <td><span class="badge bg-success px-2 py-2">Concluído</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="tela-produtos" class="p-4 item-tela d-none">
                <h2 class="fw-bold mb-4"><i class="bi bi-plus-circle me-2"></i>Gerenciar Cardápio (Produtos e Itens)</h2>
                <div class="bg-white p-4 rounded-4 shadow-sm">
                    <form id="formProduto">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-medium">Nome do Produto/Item</label>
                                <input id="productName" type="text" class="form-control form-control-lg" placeholder="Ex: X-Salada, Coca-Cola, Bacon Extra">
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-medium">Preço de Venda (R$)</label>
                                <input id="productPrice" type="number" step="0.01" class="form-control form-control-lg" placeholder="0,00">
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-medium">Tipo/Categoria</label>
                                <select id="productCategory" class="form-select form-select-lg">
                                    <option value="lanche">Lanche</option>
                                    <option value="bebida">Bebida</option>
                                    <option value="sobremesa">Sobremesa</option>
                                    <option value="adicional">Item Adicional (Adicionais/Insumo)</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Descrição / Ingredientes do Produto</label>
                            <textarea id="productDescription" class="form-control" rows="2" placeholder="Ex: Pão artesanal, blend bovino 150g, queijo prato prêmio..."></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-medium">Caminho da Imagem</label>
                            <input id="productImagePath" type="text" class="form-control" placeholder="Ex: /img/produtos/xsalada.png">
                        </div>
                        <button type="submit" class="btn btn-success btn-lg px-4 py-2 fw-semibold">
                            <i class="bi bi-save me-2"></i>Salvar no Sistema
                        </button>
                    </form>
                    <div id="itemList" class="mt-4"></div>
                </div>
            </div>

            <div id="tela-relatorios" class="p-4 item-tela d-none">
                <h2 class="fw-bold text-dark mb-4"><i class="bi bi-bar-chart me-2"></i>Relatórios de Vendas</h2>
                <div id="reportsContainer" class="bg-white p-4 rounded-4 shadow-sm">
                    <div class="row text-center g-3 mb-4">
                        <div class="col-md-4">
                            <div class="border rounded-3 p-3 bg-light">
                                <h6 class="text-muted mb-1">Faturamento Hoje</h6>
                                <h3 class="fw-bold text-success mb-0">R$ 1.240,00</h3>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded-3 p-3 bg-light">
                                <h6 class="text-muted mb-1">Total de Pedidos</h6>
                                <h3 class="fw-bold text-primary mb-0">42</h3>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded-3 p-3 bg-light">
                                <h6 class="text-muted mb-1">Média por Pedido</h6>
                                <h3 class="fw-bold text-dark mb-0">R$ 29,52</h3>
                            </div>
                        </div>
                    </div>
                    <p class="text-muted text-center">Dados consolidados do caixa atual.</p>
                </div>
            </div>

            <div id="tela-estoque" class="p-4 item-tela d-none">
                <h2 class="fw-bold text-dark mb-4"><i class="bi bi-box-seam me-2"></i> Controle de Estoque Atual</h2>
                <div class="bg-white p-4 rounded-4 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Item / Insumo</th>
                                    <th>Categoria</th>
                                    <th>Qtd. Atual</th>
                                    <th>Status de Alerta</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody id="estoqueList">
                                <tr>
                                    <td class="fw-semibold">Bacon</td>
                                    <td>Insumo / Adicional</td>
                                    <td class="fw-bold text-dark">20 Unid</td>
                                    <td><span class="badge bg-warning text-dark px-2 py-1">Estoque Crítico</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold">Pão de Hambúrguer</td>
                                    <td>Insumo Base</td>
                                    <td class="fw-bold text-dark">50 Unid</td>
                                    <td><span class="badge bg-success px-2 py-1">Estoque OK</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold">Blend de Carne (150g)</td>
                                    <td>Insumo Base</td>
                                    <td class="fw-bold text-dark">65 Unid</td>
                                    <td><span class="badge bg-success px-2 py-1">Estoque OK</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold">Queijo Prato Cheddar</td>
                                    <td>Insumo / Adicional</td>
                                    <td class="fw-bold text-dark">40 Unid</td>
                                    <td><span class="badge bg-success px-2 py-1">Estoque OK</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold">Batata Palito Congelada</td>
                                    <td>Porção / Insumo</td>
                                    <td class="fw-bold text-dark">15 kg</td>
                                    <td><span class="badge bg-warning text-dark px-2 py-1">Estoque Moderado</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="/script.js"></script>
</body>

</html>