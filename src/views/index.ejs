<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PDV - Luizão Lanches</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <!-- ═══════════════════════ SIDEBAR ═══════════════════════ -->
  <div class="sidebar">
    <div>
      <div class="logo mb-4">
        <img src="/img/logo.png" alt="Luizão Lanches">
      </div>

      <nav class="menu">
        <button class="menu-item a active" data-tela="tela-venda">
          <i class="bi bi-cart-fill"></i>Venda
        </button>

        <button class="menu-item b" data-tela="tela-pedidos">
          <i class="bi bi-receipt"></i>Pedidos
        </button>

        <button class="menu-item e" data-tela="tela-relatorios">
          <i class="bi bi-bar-chart"></i>Relatórios
        </button>

        <!-- Visível apenas para ADMIN (ocultado via JS para ATTENDANT) -->
        <button class="menu-item c admin-only" data-tela="tela-produtos">
          <img src="/img/hamburguer.svg" class="icone-menu" alt="">
          Produtos
        </button>

        <button class="menu-item d" data-tela="tela-estoque">
          <i class="bi bi-box-seam"></i>Estoque
        </button>
      </nav>
    </div>
  </div>

  <!-- ═══════════════════════ MAIN ═══════════════════════════ -->
  <div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
      <h3 class="fw-bold mb-0">PDV — PONTO DE VENDA</h3>

      <div class="d-flex align-items-center gap-4">
        <span>
          <i class="bi bi-calendar-event me-1"></i>
          <span id="dataAtual"></span>
        </span>
        <span>
          <i class="bi bi-clock me-1"></i>
          <span id="horaAtual"></span>
        </span>

        <div class="user-box">
          <!-- Preenchido via JS com dados do localStorage -->
          <div class="fw-bold" id="topbarNome">—</div>
          <small id="topbarRole"></small>
        </div>

        <button id="btnLogout" class="btn btn-sm btn-outline-light">
          <i class="bi bi-box-arrow-right"></i> Sair
        </button>
      </div>
    </header>

    <!-- CONTEÚDO DAS TELAS -->
    <div class="content container-fluid p-0">

      <!-- ── TELA VENDA ──────────────────────────────────────── -->
      <div id="tela-venda" class="row h-100 m-0 item-tela">

        <!-- Área de produtos -->
        <div class="col-lg-8 products-area">
          <div class="row mb-4">
            <div class="col-lg-9">
              <!-- Input de busca → applyFilters() filtra #productsGrid -->
              <input id="searchInput" type="text" class="form-control search-input"
                placeholder="Buscar produtos...">
            </div>
          </div>

          <!-- Filtros de categoria (visuais — sem field de categoria na API) -->
          <div class="row mb-4 g-3">
            <div class="col-md-4">
              <button class="category-btn active" data-category="lanche">Lanches</button>
            </div>
            <div class="col-md-4">
              <button class="category-btn" data-category="bebida">Bebidas</button>
            </div>
            <div class="col-md-4">
              <button class="category-btn" data-category="sobremesa">Sobremesas</button>
            </div>
          </div>

          <!-- Injetado por loadProductCards() em order.js via GET /luizao/products -->
          <div id="productsGrid" class="row g-4">
            <div class="col-12 text-center text-muted py-5">
              <div class="spinner-border text-success" role="status" aria-hidden="true"></div>
              <p class="mt-2 mb-0">Carregando produtos...</p>
            </div>
          </div>
        </div>

        <!-- Área do carrinho / pedido atual -->
        <div class="col-lg-4 order-area">
          <div>
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="fw-bold mb-0">Pedido Atual</h2>
              <button id="limparPedido" class="btn clear-btn">Limpar pedido</button>
            </div>

            <!-- Injetado por renderCarrinho() em order.js -->
            <div id="pedidoAtual"></div>
          </div>

          <div class="fundo mt-auto">
            <div class="p-2 text-center border rounded-3 bg-light mb-4">
              <h5 class="m-0 fw-bold text-muted">
                Subtotal: <span id="subtotal">R$ 0,00</span>
              </h5>
            </div>

            <div class="pay-card">
              <button id="finalizarPedido" class="text-white bg-success w-100">
                Finalizar
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- ── TELA PAGAMENTO — MÉTODO ─────────────────────────── -->
      <div id="tela-dinheiro" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4">
          <i class="bi bi-cash-stack me-2"></i>Escolha o Método de Pagamento
        </h2>

        <div class="bg-white p-4 rounded-4 shadow-sm">
          <!-- Injetado por renderPaymentSummary() em sales.js -->
          <div id="paymentSummary" class="mb-4"></div>

          <div class="d-flex flex-wrap gap-3">
            <button type="button" class="btn btn-success payment-method-btn" data-method="Dinheiro">
              <i class="bi bi-cash me-1"></i>Dinheiro
            </button>
            <button type="button" class="btn btn-primary payment-method-btn" data-method="Cartão">
              <i class="bi bi-credit-card me-1"></i>Cartão
            </button>
            <button type="button" class="btn btn-warning payment-method-btn" data-method="Pix">
              <i class="bi bi-qr-code me-1"></i>Pix
            </button>
          </div>

          <div class="mt-4 d-flex gap-2">
            <button id="voltarVenda" class="btn btn-secondary">
              <i class="bi bi-arrow-left me-1"></i>Voltar para Venda
            </button>
            <button id="cancelarPagamento" class="btn btn-outline-danger">
              <i class="bi bi-x-circle me-1"></i>Cancelar e Limpar
            </button>
          </div>

          <!-- Feedback após confirmar pagamento — injetado por completeOrder() em sales.js -->
          <div id="paymentMessage" class="mt-3 fw-semibold text-success"></div>
        </div>
      </div>

      <!-- ── TELA CARTÃO ─────────────────────────────────────── -->
      <div id="tela-cartao" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4">
          <i class="bi bi-credit-card-2-front me-2"></i>Cartão: escolha o tipo
        </h2>

        <div class="bg-white p-4 rounded-4 shadow-sm">
          <p class="text-muted mb-4" id="cardTypeMessage">
            Selecione Crédito ou Débito para continuar.
          </p>

          <div class="d-flex flex-wrap gap-3 mb-4">
            <button type="button" class="btn btn-outline-primary card-type-btn" data-card-type="Crédito">
              <i class="bi bi-credit-card me-1"></i>Crédito
            </button>
            <button type="button" class="btn btn-outline-primary card-type-btn" data-card-type="Débito">
              <i class="bi bi-credit-card-2-back me-1"></i>Débito
            </button>
          </div>

          <div class="d-flex gap-2">
            <button id="finalizarCartao" class="btn btn-success" disabled>
              <i class="bi bi-check-circle me-1"></i>Finalizar Pagamento
            </button>
            <button id="voltarMetodo" class="btn btn-secondary">
              <i class="bi bi-arrow-left me-1"></i>Voltar ao Método
            </button>
            <button id="cancelarCartao" class="btn btn-outline-danger">
              <i class="bi bi-x-circle me-1"></i>Cancelar e Limpar
            </button>
          </div>
        </div>
      </div>

      <!-- ── TELA PEDIDOS ───────────────────────────────────── -->
      <div id="tela-pedidos" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4">
          <i class="bi bi-receipt me-2"></i>Histórico de Pedidos
        </h2>

        <!-- Injetado por updateOrdersView() em report.js via GET /luizao/orders -->
        <div id="pedidosList" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

      <!-- ── TELA PRODUTOS (ADMIN ONLY) ─────────────────────── -->
      <div id="tela-produtos" class="p-4 item-tela d-none admin-only">
        <h2 class="fw-bold mb-4">Gestão de Produtos</h2>

        <ul class="nav nav-tabs mb-4" id="produtosTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-itens"
              data-bs-toggle="tab" data-bs-target="#painel-itens"
              type="button" role="tab">Itens do Menu</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-ingredientes"
              data-bs-toggle="tab" data-bs-target="#painel-ingredientes"
              type="button" role="tab">Ingredientes</button>
          </li>
        </ul>

        <div class="tab-content">

          <!-- TAB — ITENS DO MENU -->
          <div class="tab-pane fade show active" id="painel-itens" role="tabpanel">

            <!-- Formulário de novo item → POST /luizao/items (admin-products.js) -->
            <div class="bg-white p-4 rounded-4 shadow-sm mb-4">
              <h5 class="fw-bold mb-3">Novo Item</h5>
              <form id="formNovoItem" class="row g-3">
                <div class="col-md-4">
                  <label class="form-label" for="itemNome">Nome</label>
                  <input type="text" class="form-control" id="itemNome" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label" for="itemDescricao">Descrição</label>
                  <input type="text" class="form-control" id="itemDescricao">
                </div>
                <div class="col-md-2">
                  <label class="form-label" for="itemPreco">Preço (R$)</label>
                  <input type="number" class="form-control" id="itemPreco"
                    min="0.01" step="0.01" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                  <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-plus-circle me-1"></i>Salvar
                  </button>
                </div>
              </form>
              <div id="itemAlertBox" class="mt-2"></div>
            </div>

            <!-- Tabela preenchida por loadItens() em admin-products.js via GET /luizao/items -->
            <div class="bg-white p-4 rounded-4 shadow-sm">
              <h5 class="fw-bold mb-3">Itens Cadastrados</h5>
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>#</th>
                      <th>Nome</th>
                      <th>Descrição</th>
                      <th>Preço</th>
                      <th>Status</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody id="itensTableBody">
                    <tr>
                      <td colspan="6" class="text-center text-muted">Carregando...</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- TAB — INGREDIENTES (Estoque) -->
          <div class="tab-pane fade" id="painel-ingredientes" role="tabpanel">

            <!-- Formulário de novo ingrediente → POST /luizao/products (admin-products.js) -->
            <div class="bg-white p-4 rounded-4 shadow-sm mb-4">
              <h5 class="fw-bold mb-3">Novo Ingrediente</h5>
              <form id="formNovoIngrediente" class="row g-3">
                <div class="col-md-4">
                  <label class="form-label" for="ingNome">Nome</label>
                  <input type="text" class="form-control" id="ingNome" required>
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="ingEstoqueMin">Estoque Mínimo</label>
                  <input type="number" class="form-control" id="ingEstoqueMin" min="0" value="0">
                </div>
                <div class="col-md-3">
                  <label class="form-label" for="ingEstoqueAtual">Quantidade em Estoque</label>
                  <input type="number" class="form-control" id="ingEstoqueAtual" min="0" value="0">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                  <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-plus-circle me-1"></i>Salvar
                  </button>
                </div>
              </form>
              <div id="ingAlertBox" class="mt-2"></div>
            </div>

            <!-- Tabela preenchida por loadIngredientes() em admin-products.js via GET /luizao/products -->
            <div class="bg-white p-4 rounded-4 shadow-sm">
              <h5 class="fw-bold mb-3">Ingredientes Cadastrados</h5>
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>#</th>
                      <th>Nome</th>
                      <th>Estoque Mín.</th>
                      <th>Estoque Atual</th>
                      <th>Status</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody id="ingredientesTableBody">
                    <tr>
                      <td colspan="6" class="text-center text-muted">Carregando...</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ── TELA RELATÓRIOS ───────────────────────────────── -->
      <div id="tela-relatorios" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4">
          <i class="bi bi-bar-chart me-2"></i>Relatórios de Vendas
        </h2>

        <!-- Injetado por updateReportsView() em report.js via GET /luizao/sales -->
        <div id="reportsContainer" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

      <!-- ── TELA ESTOQUE ───────────────────────────────────── -->
      <div id="tela-estoque" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4">
          <i class="bi bi-box-seam me-2"></i>Estoque
        </h2>

        <!-- Injetado por updateEstoqueView() em report.js via GET /luizao/products -->
        <div id="estoqueList" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->

  <!-- ═══════════════ MODAL — ASSOCIAR INGREDIENTES ═══════════ -->
  <div class="modal fade" id="modalIngredientes" tabindex="-1"
    aria-labelledby="modalIngredientesLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalIngredientesLabel">Associar Ingredientes</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <!-- Nome do item selecionado — preenchido por abrirIngredientes() em admin-products.js -->
          <p class="text-muted mb-3" id="modalItemNome"></p>

          <!-- Checkboxes injetados dinamicamente via GET /luizao/products -->
          <div id="ingredientesCheckboxes">
            <div class="text-center text-muted">Carregando ingredientes...</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary" id="btnSalvarIngredientes">
            <i class="bi bi-save me-1"></i>Salvar Associações
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Ponto de entrada da SPA — carrega todos os módulos via import -->
  <script type="module" src="/js/script.js"></script>
</body>

</html>
