<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PDV - Luizão Lanches</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>

<body>

  <div class="sidebar">
    <div>
      <div class="logo mb-4">
        <img src="/img/logo.png" alt="Logo">
      </div>

      <div class="menu">
        <button class="menu-item a active" data-tela="tela-venda">
          <i class="bi bi-cart-fill"></i>
          Venda
        </button>

        <button class="menu-item b" data-tela="tela-pedidos">
          <i class="bi bi-receipt"></i>
          Pedidos
        </button>

        <button class="menu-item e" data-tela="tela-relatorios">
          <i class="bi bi-bar-chart"></i>
          Relatórios
        </button>

        <button class="menu-item c admin-only" data-tela="tela-produtos">
          <img src="/img/hamburguer.svg" class="icone-menu" alt="Produtos">
          Produtos
        </button>

        <button class="menu-item d" data-tela="tela-estoque">
          <i class="bi bi-box-seam"></i>
          Estoque
        </button>
      </div>
    </div>
  </div>

  <div class="main">
    <div class="topbar">
      <h3 class="fw-bold mb-0">PDV - PONTO DE VENDA</h3>

      <div class="d-flex align-items-center gap-4">
        <span>
          <i class="bi bi-calendar-event me-2"></i>
          <span id="dataAtual"></span>
        </span>

        <span>
          <i class="bi bi-clock me-2"></i>
          <span id="horaAtual"></span>
        </span>

        <div class="user-box">
          <div class="fw-bold" id="topbarNome">Caixa 01</div>
          <small id="topbarRole">Operador</small>
        </div>

        <button id="btnLogout" class="btn btn-sm btn-outline-danger">
          <i class="bi bi-box-arrow-right"></i> Sair
        </button>
      </div>
    </div>

    <div class="content container-fluid">

      <!-- TELA VENDA -->
      <div id="tela-venda" class="row h-100 m-0 item-tela">
        <div class="col-lg-8 products-area">
          <div class="row mb-4">
            <div class="col-lg-9">
              <input id="searchInput" type="text" class="form-control search-input" placeholder="Buscar produtos...">
            </div>
          </div>

          <div class="row mb-4 g-3">
            <div class="col-md-4">
              <button id="item-lanche" class="category-btn active" data-category="lanche">Lanches</button>
            </div>
            <div class="col-md-4">
              <button class="category-btn" data-category="bebida">Bebidas</button>
            </div>
            <div class="col-md-4">
              <button class="category-btn" data-category="sobremesa">Sobremesas</button>
            </div>
          </div>

          <div class="row g-4">
            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="X-Burguer" data-preco="18" data-category="lanche" data-stock="8" data-img="/img/Xburguer2.png">
                <div class="imagem"><img src="/img/Xburguer2.png" alt="Burger"></div>
                <div class="product-title">X-Burguer</div>
                <div class="product-description">Pão artesanal, carne, queijo, alface e tomate.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 18,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Batata Frita" data-preco="15" data-category="lanche" data-stock="10" data-img="/img/batata.png">
                <div class="imagem"><img src="/img/batata.png" alt="fritas"></div>
                <div class="product-title">Batatas c/Bacon</div>
                <div class="product-description">500g Batata bacon e cheddar.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 15,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Nuggets" data-preco="16" data-category="lanche" data-stock="15" data-img="/img/nugget.png">
                <div class="imagem"><img src="/img/nugget.png" alt="nugget"></div>
                <div class="product-title">Nuggets</div>
                <div class="product-description">12 unidades de nuggets super crocante.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 16,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="X-Bacon" data-preco="24" data-category="lanche" data-stock="6" data-img="/img/xbacon%20(2).png">
                <div class="imagem"><img src="/img/xbacon%20(2).png" alt="Burger"></div>
                <div class="product-title">X-Bacon</div>
                <div class="product-description">Pão artesanal, queijo e bacon crocante.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 24,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Refrigerante" data-preco="7" data-category="bebida" data-stock="20" data-img="/img/refrigerante%20(2).png">
                <div class="imagem"><img src="/img/refrigerante%20(2).png" alt="refrigerante"></div>
                <div class="product-title">Refrigerante</div>
                <div class="product-description">Refrigerante Lata 350ml, bem gelada.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 7,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Suco Natural" data-preco="9" data-category="bebida" data-stock="12" data-img="/img/suco.png">
                <div class="imagem"><img src="/img/suco.png" alt="suco"></div>
                <div class="product-title">Suco Natural</div>
                <div class="product-description">Suco Natural de laranja 300ml.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 9,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Milkshake" data-preco="18" data-category="bebida" data-stock="8" data-img="/img/milkshake.png">
                <div class="imagem"><img src="/img/milkshake.png" alt="milkshake"></div>
                <div class="product-title">Milkshake</div>
                <div class="product-description">Chocolate cremoso 500ml.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 18,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="Sorvete" data-preco="8" data-category="sobremesa" data-stock="14" data-img="/img/sorvete.png">
                <div class="imagem"><img src="/img/sorvete.png" alt="sorvete"></div>
                <div class="product-title">Sorvete</div>
                <div class="product-description">Casquinha sabores variados.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 8,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>

            <div class="col-lg-4 col-md-6">
              <div class="product-card" data-nome="X-Tudo" data-preco="15" data-category="lanche" data-stock="7" data-img="/img/xtudo%20(2).png">
                <div class="imagem"><img src="/img/xtudo%20(2).png" alt="xtudo"></div>
                <div class="product-title">X-Tudo</div>
                <div class="product-description">Pão artesanal e tudo de bom.</div>
                <div class="d-flex justify-content-between align-items-center mt-4">
                  <div class="price">R$ 15,00</div>
                  <button class="add-btn">+</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-4 order-area">
          <div>
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="fw-bold mb-0">Pedido Atual</h2>
              <button id="limparPedido" class="btn clear-btn">Limpar pedido</button>
            </div>
            <div id="pedidoAtual"></div>
          </div>

          <div class="fundo mt-auto">
            <div class="p-2 text-center border rounded-3 bg-light mb-4">
              <h5 class="m-0 fw-bold text-muted">Subtotal: <span id="subtotal">R$ 0,00</span></h5>
            </div>

            <div class="row g-2 mb-2">
              <div class="col-10 w-100">
                <div class="pay-card">
                  <button id="finalizarPedido" data-tela="tela-dinheiro" class="text-white bg-success w-100">Finalizar</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- TELA PAGAMENTO - MÉTODO -->
      <div id="tela-dinheiro" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4"><i class="bi bi-cash-stack me-2"></i>Escolha o Método de Pagamento</h2>
        <div class="bg-white p-4 rounded-4 shadow-sm">
          <div id="paymentSummary" class="mb-4"></div>
          <div class="d-flex flex-wrap gap-3">
            <button type="button" class="btn btn-success payment-method-btn" data-method="Dinheiro">Dinheiro</button>
            <button type="button" class="btn btn-primary payment-method-btn" data-method="Cartão">Cartão</button>
            <button type="button" class="btn btn-warning payment-method-btn" data-method="Pix">Pix</button>
          </div>
          <div class="mt-4 d-flex gap-2">
            <button id="voltarVenda" class="btn btn-secondary">Voltar para Venda</button>
            <button id="cancelarPagamento" class="btn btn-outline-danger">Cancelar e Limpar</button>
          </div>
          <div id="paymentMessage" class="mt-3 text-success fw-semibold"></div>
        </div>
      </div>

      <!-- TELA CARTÃO -->
      <div id="tela-cartao" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4"><i class="bi bi-credit-card-2-front me-2"></i>Cartão: escolha o tipo</h2>
        <div class="bg-white p-4 rounded-4 shadow-sm">
          <div id="cardTypeMessage" class="mb-4 text-muted">Selecione Crédito ou Débito para continuar.</div>
          <div class="d-flex flex-wrap gap-3 mb-4">
            <button type="button" class="btn btn-outline-primary card-type-btn" data-card-type="Crédito">
              <i class="bi bi-credit-card me-1"></i>Crédito
            </button>
            <button type="button" class="btn btn-outline-primary card-type-btn" data-card-type="Débito">
              <i class="bi bi-credit-card-2-back me-1"></i>Débito
            </button>
          </div>
          <div class="d-flex gap-2 mt-3">
            <button id="finalizarCartao" class="btn btn-success" disabled>
              <i class="bi bi-check-circle me-1"></i>Finalizar Pagamento
            </button>
            <button id="voltarMetodo" class="btn btn-secondary">Voltar ao Método</button>
            <button id="cancelarCartao" class="btn btn-outline-danger">Cancelar e Limpar</button>
          </div>
        </div>
      </div>

      <!-- TELA PEDIDOS -->
      <div id="tela-pedidos" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4"><i class="bi bi-receipt me-2"></i>Histórico de Pedidos</h2>
        <div id="pedidosList" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

      <!-- TELA PRODUTOS (ADMIN) -->
      <div id="tela-produtos" class="p-4 item-tela d-none">
        <h2 class="fw-bold mb-4">Gestão de Produtos</h2>

        <ul class="nav nav-tabs mb-4" id="produtosTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-itens" data-bs-toggle="tab" data-bs-target="#painel-itens"
              type="button" role="tab">Itens do Menu</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-ingredientes" data-bs-toggle="tab" data-bs-target="#painel-ingredientes"
              type="button" role="tab">Ingredientes</button>
          </li>
        </ul>

        <div class="tab-content">

          <!-- TAB ITENS -->
          <div class="tab-pane fade show active" id="painel-itens" role="tabpanel">
            <div class="bg-white p-4 rounded-4 shadow-sm mb-4">
              <h5 class="fw-bold mb-3">Novo Item</h5>
              <form id="formNovoItem" class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Nome</label>
                  <input type="text" class="form-control" id="itemNome" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Descrição</label>
                  <input type="text" class="form-control" id="itemDescricao">
                </div>
                <div class="col-md-2">
                  <label class="form-label">Preço (R$)</label>
                  <input type="number" class="form-control" id="itemPreco" min="0.01" step="0.01" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                  <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-plus-circle me-1"></i>Salvar
                  </button>
                </div>
              </form>
              <div id="itemAlertBox" class="mt-2"></div>
            </div>

            <div class="bg-white p-4 rounded-4 shadow-sm">
              <h5 class="fw-bold mb-3">Itens Cadastrados</h5>
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>#</th>
                      <th>Nome</th>
                      <th>Descrição</th>
                      <th>Preço</th>
                      <th>Status</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody id="itensTableBody">
                    <tr><td colspan="6" class="text-center text-muted">Carregando...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- TAB INGREDIENTES -->
          <div class="tab-pane fade" id="painel-ingredientes" role="tabpanel">
            <div class="bg-white p-4 rounded-4 shadow-sm mb-4">
              <h5 class="fw-bold mb-3">Novo Ingrediente</h5>
              <form id="formNovoIngrediente" class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Nome</label>
                  <input type="text" class="form-control" id="ingNome" required>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Estoque Mínimo</label>
                  <input type="number" class="form-control" id="ingEstoqueMin" min="0" value="0">
                </div>
                <div class="col-md-3">
                  <label class="form-label">Quantidade em Estoque</label>
                  <input type="number" class="form-control" id="ingEstoqueAtual" min="0" value="0">
                </div>
                <div class="col-md-2 d-flex align-items-end">
                  <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-plus-circle me-1"></i>Salvar
                  </button>
                </div>
              </form>
              <div id="ingAlertBox" class="mt-2"></div>
            </div>

            <div class="bg-white p-4 rounded-4 shadow-sm">
              <h5 class="fw-bold mb-3">Ingredientes Cadastrados</h5>
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>#</th>
                      <th>Nome</th>
                      <th>Estoque Mín.</th>
                      <th>Estoque Atual</th>
                      <th>Status</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody id="ingredientesTableBody">
                    <tr><td colspan="6" class="text-center text-muted">Carregando...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- TELA RELATÓRIOS -->
      <div id="tela-relatorios" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4"><i class="bi bi-bar-chart me-2"></i>Relatórios de Vendas</h2>
        <div id="reportsContainer" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

      <!-- TELA ESTOQUE -->
      <div id="tela-estoque" class="p-4 item-tela d-none">
        <h2 class="fw-bold text-dark mb-4"><i class="bi bi-box-seam"></i> Estoque</h2>
        <div id="estoqueList" class="bg-white p-4 rounded-4 shadow-sm"></div>
      </div>

    </div>
  </div>

  <!-- MODAL ASSOCIAR INGREDIENTES -->
  <div class="modal fade" id="modalIngredientes" tabindex="-1" aria-labelledby="modalIngredientesLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalIngredientesLabel">Associar Ingredientes</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3" id="modalItemNome"></p>
          <div id="ingredientesCheckboxes">
            <div class="text-center text-muted">Carregando ingredientes...</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary" id="btnSalvarIngredientes">
            <i class="bi bi-save me-1"></i>Salvar Associações
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="script.js"></script>
</body>

</html>
