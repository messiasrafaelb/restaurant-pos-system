<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="formulario.css">
</head>

<body>
 <div class="container">
    <div class="imagem-luiz">
        <img src="/img/Luizão.svg" alt="">
    </div>

    <div class="separa-grid">
        <div class="formulario-fundo">
            <div class="formulario-info">
                <form action="/entrar" method="get">
                    <h2>Seja Bem Vindo</h2>

                    <label for="nome">Nome</label>
                    <input type="text" id="nome" name="nome" required>

                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required placeholder="@gmail.com">

                    <label for="senha">Senha</label>
                    <input type="password" id="senha" name="senha" required>

                    <a href="/entrar">Entrar</a>
                </form>
            </div>
        </div>
    </div>
</div>
            <script>
                (function(){
                    const form = document.querySelector('form');
                    const entrar = document.querySelector('form a');
                    if(form){
                        form.addEventListener('submit', function(e){
                            e.preventDefault();
                            window.location.href = '/';
                        });
                    }
                    if(entrar){
                        entrar.addEventListener('click', function(e){
                            e.preventDefault();
                            window.location.href = '/';
                        });
                    }
                })();
            </script>
</body>

</html>